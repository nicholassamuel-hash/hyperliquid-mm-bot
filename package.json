{
  "name": "hyperliquid-mm-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Paper-trading market maker for Hyperliquid perp DEX. Phase 1: no real money.",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "paper": "tsx src/sim/runPaper.ts",
    "live": "tsx src/sim/runLive.ts",
    "record": "tsx src/sim/recorder.ts",
    "backtest": "tsx src/sim/runBacktest.ts",
    "dashboard": "tsx src/cli/dashboard.ts",
    "analyze": "tsx src/cli/analyze.ts",
    "gen-wallet": "tsx scripts/gen-wallet.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.2",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "viem": "^2.21.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
