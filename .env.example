# ============================================================================
# Hyperliquid MM Bot Configuration v2
# ============================================================================

# Coins to market-make
COINS=HYPE

# Quote mode: join (at touch) | improve (1 tick inside) | outside (legacy)
QUOTE_MODE=improve

# Half-spread bps — floor (used when natural spread very wide, also for edge gate)
HALF_SPREAD_BPS_MIN=1.5
# Half-spread bps — cap
HALF_SPREAD_BPS_MAX=20
# Volatility multiplier (effective half-spread = realized_vol * this)
VOL_MULTIPLIER=1.5

# Sizing in USD
# Smaller quote = more rounds before hitting position cap = better inventory cycling.
# QUOTE_SIZE_USD=0.5 + MAX_POSITION_USD=20 = up to 40 fills before cap (vs 10 at 2.0)
QUOTE_SIZE_USD=0.5
MAX_POSITION_USD=20
MAX_MARGIN_USD=15

# Cooldown between quote replacements (ms)
REPLACE_COOLDOWN_MS=200

# Adverse threshold (bps) floor
ADVERSE_THRESHOLD_BPS_MIN=1.5

# Funding skew kicks in when |funding| > this (per hour)
FUNDING_SKEW_THRESHOLD=0.0001

# Minimum edge after 2x fees to bother placing a quote (bps)
MIN_EDGE_BPS=0.5

# Order book imbalance influence on quote skew (0=off, 1=full)
OBI_WEIGHT=0.5
# Inventory flat-bias weight (0=off, 1=full)
INV_FLAT_WEIGHT=0.4

# --------- PHASE 2 (live) ---------
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

LOG_LEVEL=info
