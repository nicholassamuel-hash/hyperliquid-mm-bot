# ============================================================================
# Hyperliquid MM Bot Configuration v3 — Vol Pause + Multi-Coin
# ============================================================================

# Multi-coin: comma-separated tickers. Diversifies regime exposure.
# Per-coin caps apply, so total max exposure = MAX_POSITION_USD * len(COINS).
# For $30 modal with 4 coins: set MAX_POSITION_USD=7 (total ≤ $28).
COINS=BTC,ETH,SOL,HYPE

# Quote mode: join (at touch) | improve (1 tick inside) | outside (legacy)
QUOTE_MODE=join

# Half-spread bps — floor (used when natural spread very wide, also for edge gate)
HALF_SPREAD_BPS_MIN=1.5
# Half-spread bps — cap
HALF_SPREAD_BPS_MAX=20
# Volatility multiplier (effective half-spread = realized_vol * this)
VOL_MULTIPLIER=1.5

# Sizing in USD (fallback for coins not in QUOTE_SIZE_USD_BY_COIN)
QUOTE_SIZE_USD=0.5
# Per-coin quote-size override (USD), format COIN:SIZE,COIN:SIZE.
# Why: a single QUOTE_SIZE_USD floors to 0 for expensive coins — $0.5/BTC rounds
# below min size once BTC > ~$100k, so BTC/ETH never quoted. Live min-notionals
# are ~$0.6 across BTC/ETH/SOL/HYPE (2026-06), so these are ~2-3x min and stay
# well under MAX_POSITION_USD so inventory can layer fills.
QUOTE_SIZE_USD_BY_COIN=BTC:2,ETH:2,SOL:2,HYPE:1.5
# Per-coin position cap. With 4 coins running, total max = 4 * this.
MAX_POSITION_USD=7
MAX_MARGIN_USD=15

# Cooldown between quote replacements (ms)
REPLACE_COOLDOWN_MS=400

# Adverse threshold (bps) floor — drift early-warning band
ADVERSE_THRESHOLD_BPS_MIN=3
# Stale tolerance (bps): how far the opposite touch must move PAST our quote
# before we cancel. 0 = twitchy (cancels on first touch; in join mode ≈ every
# tick → ~80% adverse rate, starved fills). Set >0 (e.g. 2) to let quotes rest
# and fill; this also disables the drift check (over-fires when threshold >> spread).
ADVERSE_STALE_TOLERANCE_BPS=0

# Funding skew kicks in when |funding| > this (per hour)
FUNDING_SKEW_THRESHOLD=0.0001

# Minimum edge after 2x fees to bother placing a quote (bps)
MIN_EDGE_BPS=-3

# Order book imbalance influence on quote skew (0=off, 1=full)
OBI_WEIGHT=0.5
# Inventory flat-bias weight (0=off, 1=full)
INV_FLAT_WEIGHT=0.6

# ----- Vol spike pause (chaos protection) -----
# Pause when short-window vol exceeds baseline by this factor.
# 3 = stop trading when 5-bar vol is 3x the 30-bar vol.
VOL_SPIKE_MULTIPLIER=3
# Short window bars (recent vol estimate)
VOL_SPIKE_SHORT_BARS=5
# Baseline window bars (longer history)
VOL_SPIKE_BASELINE_BARS=30
# Pause duration after spike detection (ms). Default 60s.
VOL_PAUSE_MS=60000

# --------- PHASE 2 (live) ---------
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

LOG_LEVEL=info
